# Project Name
APP_NAME=wordpress
APP_IMAGE=registry.gitlab.com/wordpress
WEB_IMAGE=registry.gitlab.com/wordpress/nginx
APP_VERSION=latest
APP_DOMAIN=wordpress.local

# VOLUMES (point to existing Docker volumes on this server)
VOLUME_DB=wordpress_db_data
VOLUME_UPLOADS=<LOCAL_DONT_USE_THIS_ONE>

# Database Settings
DB_ROOT_PASSWORD=root
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
WORDPRESS_DB_HOST=wordpress_db

# Port Configuration
HOST_USER=1001:1001
