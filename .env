# Project Name
APP_NAME=daodo
APP_IMAGE=registry.gitlab.com/daodo
WEB_IMAGE=registry.gitlab.com/daodo/nginx
APP_VERSION=latest
APP_DOMAIN=daodo.localhost

# VOLUMES (point to existing Docker volumes on this server)
VOLUME_DB=daodo_db_data
VOLUME_UPLOADS=<LOCAL_DONT_USE_THIS_ONE>

# Database Settings
DB_ROOT_PASSWORD=root
WORDPRESS_DB_NAME=daodo
WORDPRESS_DB_USER=daodo
WORDPRESS_DB_PASSWORD=daodo
WORDPRESS_DB_HOST=daodo_db

# Port Configuration
HOST_USER=1001:1001
